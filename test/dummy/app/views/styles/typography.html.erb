<%=
ds_fixed_elements do |ds|
  ds.main_heading 'Typography', caption: 'Styles'

  ds.breadcrumb('Home', root_path)
  ds.breadcrumb('Styles', styles_path)

  ds.lead_paragraph 'Fonts and typographic styles.'
end
%>

<%= ds_heading 'Default heading', id: "default-heading", level: 3 %>
<%= component_preview id: 'default-heading' do %>
<%%= ds_heading 'Default heading' %>
<% end %>

<%= ds_heading 'Heading levels', level: 3 %>
<%= component_preview id: 'heading-levels' do %>
<%%= ds_heading 'h1', level: 1 %>
<%%= ds_heading 'h2', level: 2 %>
<%%= ds_heading 'h3', level: 3 %>
<%%= ds_heading 'h4', level: 4 %>
<%%= ds_heading 'h5', level: 5 %>
<% end %>

<br/>

<%= ds_heading 'Paragraphs', level: 3 %>
<%= component_preview id: 'paragraphs' do %>
<%%= ds_paragraph('This is a standard body paragraph.') %>
<%%= ds_paragraph('This is a smaller body paragraph.', size: :s) %>
<% end %>
