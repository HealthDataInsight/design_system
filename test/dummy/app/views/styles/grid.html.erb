<%=
ds_fixed_elements do |ds|
  ds.main_heading 'Grid system', caption: 'Layout'

  ds.breadcrumb('Home', root_path)
  ds.breadcrumb('Styles', styles_path)

  ds.lead_paragraph "Use the grid system to lay out the content on your service's pages."
end
%>

<%= component_preview :grid_full_width do %>
<%%= ds_grid do |row| %>
  <%% row.add_column(:full) do %>
    <%%= ds_paragraph 'Full width column.' %>
  <%% end %>
<%% end %>
<% end %>

<%= component_preview :grid_one_half do %>
<%%= ds_grid do |row| %>
  <%% row.add_column(:one_half) do %>
    <%%= ds_paragraph 'One-half column.' %>
  <%% end %>
<%% end %>
<% end %>

<%= component_preview :grid_two_thirds do %>
<%%= ds_grid do |row| %>
  <%% row.add_column(:two_thirds) do %>
    <%%= ds_paragraph 'Two-thirds column.' %>
  <%% end %>
<%% end %>
<% end %>

<%= component_preview :grid_one_third do %>
<%%= ds_grid do |row| %>
  <%% row.add_column(:one_third) do %>
    <%%= ds_paragraph 'One-third column.' %>
  <%% end %>
<%% end %>
<% end %>

<%= component_preview :grid_three_quarters do %>
<%%= ds_grid do |row| %>
  <%% row.add_column(:three_quarters) do %>
    <%%= ds_paragraph 'Three-quarters column.' %>
  <%% end %>
<%% end %>
<% end %>

<%= component_preview :grid_one_quarter do %>
<%%= ds_grid do |row| %>
  <%% row.add_column(:one_quarter) do %>
    <%%= ds_paragraph 'One-quarter column.' %>
  <%% end %>
<%% end %>
<% end %>

<%= component_preview :grid_nested do %>
<%%= ds_grid do |row| %>
  <%% row.add_column(:two_thirds) do %>
    <%%= ds_heading 'Two-thirds column', level: 4 %>
    <%%= ds_grid do |inner_rows| %>
      <%% inner_rows.add_column(:one_half) do %>
        <%%= ds_heading 'Half column', level: 5 %>
        <%%= ds_paragraph 'This is a nested half-width column.' %>
      <%% end %>
      <%% inner_rows.add_column(:one_half) do %>
        <%%= ds_heading 'Half column', level: 5 %>
        <%%= ds_paragraph 'This is another nested half-width column.' %>
      <%% end %>
    <%% end %>
  <%% end %>

  <%% row.add_column(:one_third) do %>
    <%%= ds_heading 'One-third column', level: 4 %>
    <%%= ds_paragraph 'This column demonstrates a one-third width column alongside the two-thirds example.' %>
  <%% end %>
<%% end %>
<% end %>
