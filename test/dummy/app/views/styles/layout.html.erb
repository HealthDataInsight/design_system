<%=
ds_fixed_elements do |ds|
  ds.main_heading 'Layout', caption: 'Styles'

  ds.breadcrumb('Home', root_path)
  ds.breadcrumb('Styles', styles_path)

  ds.lead_paragraph 'Structure your page content and elements.'
end
%>

<%= ds_heading 'Grid system', level: 2 %>

<%= ds_heading 'Full width', level: 3 %>
<%= component_preview id: 'grid-full-width' do %>
<%%= ds_grid do |row| %>
  <%% row.add_column(:full) do %>
    <%%= ds_paragraph 'Full width column.' %>
  <%% end %>
<%% end %>
<% end %>

<%= ds_heading 'One-half', level: 3 %>
<%= component_preview id: 'grid-one-half' do %>
<%%= ds_grid do |row| %>
  <%% row.add_column(:one_half) do %>
    <%%= ds_paragraph 'One-half column.' %>
  <%% end %>
<%% end %>
<% end %>

