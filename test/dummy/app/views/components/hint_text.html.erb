<%=
ds_fixed_elements do |ds|
  ds.main_heading 'Hint text', caption: 'Form elements'

  ds.breadcrumb('Home', root_path)
  ds.breadcrumb('Components', components_path)

  ds.lead_paragraph 'Use hint text to help users understand a question.'
end
%>

<%=
case brand
when 'nhsuk' then
  component_reference 'hint text', '/components/hint-text'
end
%>

<%= component_preview id: 'hint-text-basic', component: :form_group do %>
<%%= ds_form_with(model: Assistant.new) do |f|
  f.ds_text_field :title, width: 20, hint: "Demo for ds_text_field hint", class: "#{brand}-input--width-30"
end %>
<% end %>
