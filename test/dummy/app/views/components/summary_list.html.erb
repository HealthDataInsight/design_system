<%=
ds_fixed_elements do |ds|
  ds.main_heading 'Summary list', caption: 'Content presentation'

  ds.breadcrumb('Home', root_path)
  ds.breadcrumb('Components', components_path)

  ds.lead_paragraph "Use the summary list to summarise information, for example, a user's responses at the end of a form."
end
%>

<%= component_preview id: 'summary-list-basic' do %>
<%%=
ds_summary_list do |list|
  list.add_row('Name', 'John Doe') do |row|
    row.add_action('Root', path: '#', hidden_text: 'name')
    row.add_action('Change', hidden_text: 'name')
  end
  list.add_row('Age', 30) do |row|
    row.add_action('View')
  end
  list.add_row('Email') do |row|
    row.add_value('Enter email information', path: '#')
    row.add_action('View')
  end
  list.add_row('Contact') do |row|
    row.add_value('0123456789')
    row.add_value('john.doe@email.com')
    row.add_action('View')
  end
end
%>
<% end %>
