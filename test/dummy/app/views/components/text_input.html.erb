<%=
ds_fixed_elements do |ds|
  ds.main_heading 'Text input', caption: 'Form elements'

  ds.breadcrumb('Home', root_path)
  ds.breadcrumb('Components', components_path)

  ds.lead_paragraph 'Use text input to let users enter a single line of text.'
end
%>

<%= component_preview id: 'text-input-basic', component: :form_group do %>
<%%= ds_form_with(model: Assistant.new) do |f|
  f.ds_text_field :title, width: 20, hint: "Demo for ds_text_field", class: "#{brand}-input--width-30"
end %>
<% end %>

<%= ds_heading 'Phone number input', level: 3 %>
<%= component_preview id: 'text-input-phone', component: :form_group do %>
<%%= ds_form_with(model: Assistant.new) do |f|
  f.ds_phone_field :phone, width: 20, hint: "Demo for ds_phone_field"
end %>
<% end %>

<%= ds_heading 'Email input', level: 3 %>
<%= component_preview id: 'text-input-email', component: :form_group do %>
<%%= ds_form_with(model: Assistant.new) do |f|
  f.ds_email_field :email, width: 20, hint: "Demo for ds_email_field"
end %>
<% end %>

