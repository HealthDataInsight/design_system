end %>
<% end %>

<%= ds_heading 'Number input', level: 3 %>
<%= component_preview id: 'text-input-number', component: :form_group do %>
<%%= ds_form_with(model: Assistant.new) do |f|
  f.ds_number_field :age, width: 3, hint: "Demo for ds_number_field"
end %>
<% end %>

