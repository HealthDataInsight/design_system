<%=
ds_fixed_elements do |ds|
  ds.main_heading 'Buttons', caption: 'Form elements'

  ds.breadcrumb('Home', root_path)
  ds.breadcrumb('Components', components_path)

  ds.lead_paragraph 'Use buttons to help users carry out an action on a page like starting an application or saving their progress.'
end
%>

<%= component_preview heading: 'Start button', id: 'buttons-start' do %>
<%%= ds_start_button('Start now', '#', {'data-scrollable': 'Y'}) %>
<% end %>

<%= component_preview heading: 'Primary button', id: 'buttons-primary' do %>
<%%= ds_button_tag('Save and continue', style: 'primary', 'data-id': 1) %>
<% end %>

<%= component_preview heading: 'Secondary button', id: 'buttons-secondary' do %>
<%%= ds_button_tag('Find my location', style: 'secondary') %>
<% end %>

<%= component_preview heading: 'Warning button', id: 'buttons-warning' do %>
<%%= ds_button_tag('Yes, delete', style: 'warning') %>
<% end %>

<%= component_preview heading: 'Disabled button', id: 'buttons-disabled' do %>
<%%= ds_button_tag('Reset', type: 'reset', disabled: true) %>
<% end %>

<%= component_preview heading: 'Submit buttons (form)', id: 'buttons-submit', component: :fieldset do %>
<%%= ds_form_with(model: Assistant.new, html: { onsubmit: 'return false;' }) do |f| %>
  <%%= f.ds_field_set_tag "Submit buttons" do %>
    <%%= f.ds_submit %>
    <%%= f.ds_submit "Draft", type: :secondary %>
    <%%= f.ds_submit "Warning", type: :warning %>
    <%%= f.ds_submit "Disabled", type: :secondary, disabled: true %>
  <%% end %>
<%% end %>
<% end %>
