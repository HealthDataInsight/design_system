<%=
ds_fixed_elements do |ds|
  ds.main_heading 'Checkboxes', caption: 'Form elements'

  ds.breadcrumb('Home', root_path)
  ds.breadcrumb('Components', components_path)

  ds.lead_paragraph 'Use checkboxes to let users select 1 or more options on a form.'
end
%>

<%= component_preview id: 'checkboxes-single', component: :form_group do %>
<%%= ds_form_with(model: Assistant.new) do |f|
  f.ds_check_boxes_fieldset :terms_agreed, multiple: false, hint: 'Click to tick the box', legend: { size: 'm' } do
    f.ds_check_box :terms_agreed, { multiple: false, link_errors: true }, true, false
  end
end %>
<% end %>

<%= component_preview heading: 'Checkbox items with hints', id: 'checkboxes-hint', component: :form_group do %>
<%%= ds_form_with(model: Assistant.new) do |f|
  f.ds_check_boxes_fieldset :terms_agreed, multiple: false, legend: { size: 'm' } do
    f.ds_check_box :terms_agreed, { multiple: false, link_errors: true, hint: 'This is a item-level hint' }, true, false
  end
end %>
<% end %>

