  <%%= f.ds_check_boxes_fieldset :desired_filling, multiple: true, small: true do %>
    <%%= f.ds_check_box :desired_filling, { multiple: true }, :pastrami %>
    <%%= f.ds_check_box :desired_filling, { multiple: true }, :cheddar %>
