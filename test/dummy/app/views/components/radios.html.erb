<%=
ds_fixed_elements do |ds|
  ds.main_heading 'Radios', caption: 'Form elements'

  ds.breadcrumb('Home', root_path)
  ds.breadcrumb('Components', components_path)

  ds.lead_paragraph 'Use radios when you want users to select only 1 option from a list.'
end
%>

<%= ds_heading 'Collection radio buttons', level: 3 %>
<%= component_preview id: 'radios-collection', component: :component do %>
<%%= ds_form_with(model: Assistant.new) do |f|
  f.ds_collection_radio_buttons :colour, Assistant::COLOURS, :id, :title, { hint_method: :description, hint: "Demo for ds_collection_radio_buttons" }, { small: true, inline: true }
end %>
<% end %>

<%= ds_heading 'Radio buttons fieldset', level: 3 %>
<%= component_preview id: 'radios-fieldset', component: :component do %>
<%%= ds_form_with(model: Assistant.new) do |f|
  f.ds_radio_buttons_fieldset :lunch_option, hint: "Demo for ds_radio_buttons_fieldset" do
    f.ds_radio_button :lunch_option, "Salad", link_errors: true
    f.ds_radio_button :lunch_option, "Jacket potato"
  end
end %>
<% end %>
