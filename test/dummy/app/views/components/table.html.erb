<%=
ds_fixed_elements do |ds|
  ds.main_heading 'Table', caption: 'Content presentation'

  ds.breadcrumb('Home', root_path)
  ds.breadcrumb('Components', components_path)

  ds.lead_paragraph 'Use a table to make it easier for users to compare and scan information.'
end
%>

<%= component_preview do %>
<%%=
ds_table(data: { test: 'table' }) do |table|
  table.caption = 'Table Caption'

  table.add_column('Name', data: {'toggle': "table" , 'sort-name': "name" , 'sort-order': "desc", 'pagination':"false"} )
  table.add_numeric_column('Age', data: { sortable: false })
  table.add_column('Medication')
  table.add_column('How much')

  table.add_row do |row|
    row.add_cell('John Doe', data: { id: 1 })
    row.add_cell(30, data: { id: 2 })
    row.add_cell('Ibuprofen')
    row.add_cell('2 pills')
  end
  table.add_row 'John Doe', 25, 'Continuous combined hormone replacement therapy (HRT) tablets, capsules and patches', '2 pills'
  table.add_row 'John Doe', 40, 'Ibuprofen', '2 pills'
  table.add_row 'John Doe', 6, 'Ibuprofen', '1 pill'
end
%>
<% end %>